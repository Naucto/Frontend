{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run lint -- --fix)",
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(npm run preview)",
      "Bash(npx jest)",
      "Bash(npx jest:*)",
      "Bash(npm run cypress:run)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ]
  }
}
